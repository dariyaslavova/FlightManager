@model X.PagedList.IPagedList<FlightManager.Data.Models.User>
@using X.PagedList.Mvc.Core
@using X.PagedList

<h2>Потребители</h2>

<form method="get" asp-action="Index">
    <input type="text" name="email" placeholder="Email" value="@Context.Request.Query["email"]" />
    <input type="text" name="username" placeholder="Username" value="@Context.Request.Query["username"]" />
    <input type="text" name="firstName" placeholder="Име" value="@Context.Request.Query["firstName"]" />
    <input type="text" name="lastName" placeholder="Фамилия" value="@Context.Request.Query["lastName"]" />
    <button type="submit">Търси</button>
</form>

<p>
    <a asp-action="Create">Създай нов потребител</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Email</th>
            <th>Username</th>
            <th>Име</th>
            <th>Фамилия</th>
            <th>Роля</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Email</td>
                <td>@item.Username</td>
                <td>@item.FirstName</td>
                <td>@item.LastName</td>
                <td>@item.Role</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Редакция</a> |
                    <a asp-action="Details" asp-route-id="@item.Id">Детайли</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Изтриване</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@Html.PagedListPager(Model, page => Url.Action("Index", new
{
    page,
    email = Context.Request.Query["email"],
    username = Context.Request.Query["username"],
    firstName = Context.Request.Query["firstName"],
    lastName = Context.Request.Query["lastName"]
}))
